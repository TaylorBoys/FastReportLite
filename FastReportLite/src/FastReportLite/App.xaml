<Application x:Class="FastReportLite.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FastReportLite.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
            <converters:ComponentTypeToVisibilityConverter x:Key="ComponentTypeToVisibilityConverter"/>
            <converters:BandTypeToVisibilityConverter x:Key="BandTypeToVisibilityConverter"/>
            <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
            
            <!-- Brushes -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#2D5A8A"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="#4A90D9"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#E67E22"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="DesignerBackgroundBrush" Color="#F5F5F5"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
            <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
            <SolidColorBrush x:Key="LightTextBrush" Color="#666666"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
