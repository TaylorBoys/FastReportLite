<Window x:Class="FastReportLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FastReportLite.ViewModels"
        xmlns:models="clr-namespace:FastReportLite.Models"
        mc:Ignorable="d"
        Title="FastReportLite - 报表设计器"
        MinWidth="1280" MinHeight="720"
        Width="1600" Height="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewReportCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenReportCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveReportCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding PreviewCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#F0F0F0">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="新建报表" Command="{Binding NewReportCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="打开报表..." Command="{Binding OpenReportCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="保存报表" Command="{Binding SaveReportCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="另存为..." Command="{Binding SaveReportAsCommand}"/>
                <Separator/>
                <MenuItem Header="导出">
                    <MenuItem Header="导出为 PDF..." Command="{Binding ExportToPdfCommand}"/>
                    <MenuItem Header="导出为 Excel..." Command="{Binding ExportToExcelCommand}"/>
                    <MenuItem Header="导出为 HTML..." Command="{Binding ExportToHtmlCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="编辑(_E)">
                <MenuItem Header="撤销" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="重做" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="剪切" InputGestureText="Ctrl+X"/>
                <MenuItem Header="复制" InputGestureText="Ctrl+C"/>
                <MenuItem Header="粘贴" InputGestureText="Ctrl+V"/>
                <Separator/>
                <MenuItem Header="删除" Command="{Binding DeleteSelectedComponentCommand}"/>
            </MenuItem>
            <MenuItem Header="视图(_V)">
                <MenuItem Header="放大" Command="{Binding ZoomInCommand}"/>
                <MenuItem Header="缩小" Command="{Binding ZoomOutCommand}"/>
                <MenuItem Header="重置缩放" Command="{Binding ResetZoomCommand}"/>
            </MenuItem>
            <MenuItem Header="报表(_R)">
                <MenuItem Header="预览" Command="{Binding PreviewCommand}" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="添加波段">
                    <MenuItem Header="报表标题" Command="{Binding AddBandCommand}" CommandParameter="{x:Static models:BandType.ReportTitle}"/>
                    <MenuItem Header="页眉" Command="{Binding AddBandCommand}" CommandParameter="{x:Static models:BandType.PageHeader}"/>
                    <MenuItem Header="分组头" Command="{Binding AddBandCommand}" CommandParameter="{x:Static models:BandType.GroupHeader}"/>
                    <MenuItem Header="数据区" Command="{Binding AddBandCommand}" CommandParameter="{x:Static models:BandType.Data}"/>
                    <MenuItem Header="分组尾" Command="{Binding AddBandCommand}" CommandParameter="{x:Static models:BandType.GroupFooter}"/>
                    <MenuItem Header="页脚" Command="{Binding AddBandCommand}" CommandParameter="{x:Static models:BandType.PageFooter}"/>
                    <MenuItem Header="报表汇总" Command="{Binding AddBandCommand}" CommandParameter="{x:Static models:BandType.ReportSummary}"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="数据(_D)">
                <MenuItem Header="添加数据源..." Command="{Binding AddDataSourceCommand}"/>
                <MenuItem Header="移除数据源" Command="{Binding RemoveDataSourceCommand}"/>
                <Separator/>
                <MenuItem Header="测试连接" Command="{Binding TestDataSourceConnectionCommand}"/>
                <MenuItem Header="刷新字段" Command="{Binding RefreshDataSourceFieldsCommand}"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="关于 FastReportLite" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Tool Bar -->
        <ToolBar Grid.Row="1" Background="#F5F5F5" ToolBarTray.IsLocked="True">
            <Button Command="{Binding NewReportCommand}" ToolTip="新建报表 (Ctrl+N)">
                <TextBlock Text="📄" FontSize="16"/>
            </Button>
            <Button Command="{Binding OpenReportCommand}" ToolTip="打开报表 (Ctrl+O)">
                <TextBlock Text="📂" FontSize="16"/>
            </Button>
            <Button Command="{Binding SaveReportCommand}" ToolTip="保存报表 (Ctrl+S)">
                <TextBlock Text="💾" FontSize="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding PreviewCommand}" ToolTip="预览 (F5)">
                <TextBlock Text="👁️" FontSize="16"/>
            </Button>
            <Separator/>
            <Button Command="{Binding ZoomOutCommand}" ToolTip="缩小">
                <TextBlock Text="➖" FontSize="16"/>
            </Button>
            <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="5,0"/>
            <Button Command="{Binding ZoomInCommand}" ToolTip="放大">
                <TextBlock Text="➕" FontSize="16"/>
            </Button>
            <Separator/>
            <Button ToolTip="撤销 (Ctrl+Z)">
                <TextBlock Text="↩️" FontSize="16"/>
            </Button>
            <Button ToolTip="重做 (Ctrl+Y)">
                <TextBlock Text="↪️" FontSize="16"/>
            </Button>
            <Separator/>
            <Button ToolTip="剪切 (Ctrl+X)">
                <TextBlock Text="✂️" FontSize="16"/>
            </Button>
            <Button ToolTip="复制 (Ctrl+C)">
                <TextBlock Text="📋" FontSize="16"/>
            </Button>
            <Button ToolTip="粘贴 (Ctrl+V)">
                <TextBlock Text="📄" FontSize="16"/>
            </Button>
        </ToolBar>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Toolbox -->
            <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbox Header -->
                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="10,8">
                        <TextBlock Text="工具箱" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                    </Border>

                    <!-- Component List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">
                            <Button Style="{StaticResource ToolBarButtonStyle}" Margin="0,2"
                                    Command="{Binding AddComponentCommand}" CommandParameter="{x:Static models:ComponentType.TextBox}"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📝" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="文本框" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBarButtonStyle}" Margin="0,2"
                                    Command="{Binding AddComponentCommand}" CommandParameter="{x:Static models:ComponentType.Picture}"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖼️" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="图片" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBarButtonStyle}" Margin="0,2"
                                    Command="{Binding AddComponentCommand}" CommandParameter="{x:Static models:ComponentType.Table}"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="表格" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBarButtonStyle}" Margin="0,2"
                                    Command="{Binding AddComponentCommand}" CommandParameter="{x:Static models:ComponentType.Chart}"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📈" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="图表" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBarButtonStyle}" Margin="0,2"
                                    Command="{Binding AddComponentCommand}" CommandParameter="{x:Static models:ComponentType.Line}"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="➖" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="线条" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ToolBarButtonStyle}" Margin="0,2"
                                    Command="{Binding AddComponentCommand}" CommandParameter="{x:Static models:ComponentType.Barcode}"
                                    HorizontalContentAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📶" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="条形码" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bands Header -->
                    <Border Grid.Row="2" Background="{StaticResource PrimaryBrush}" Padding="10,8">
                        <TextBlock Text="报表波段" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                    </Border>

                    <!-- Bands List -->
                    <ListBox Grid.Row="3" ItemsSource="{Binding CurrentReport.Bands}" 
                             SelectedItem="{Binding SelectedBand}" Margin="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Margin="4"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Center Panel - Designer -->
            <Grid Grid.Column="1">
                <!-- Design Mode -->
                <Grid Visibility="{Binding IsPreviewMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Design Area Header -->
                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="报表设计 - " Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="{Binding CurrentReport.Name}" Foreground="White" FontSize="14"/>
                            <TextBlock Text=" *" Foreground="Yellow" FontSize="14" 
                                       Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Designer Canvas -->
                    <Border Grid.Row="1" Background="{StaticResource DesignerBackgroundBrush}" ClipToBounds="True">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                      x:Name="DesignerScrollViewer">
                            <Grid Margin="20" Width="{Binding CurrentReport.PageSettings.Width}" 
                                  Height="{Binding CurrentReport.PageSettings.Height}"
                                  MinWidth="800" MinHeight="600"
                                  Background="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  x:Name="DesignerCanvas">
                                <Grid.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                                </Grid.LayoutTransform>

                                <Grid.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
                                </Grid.Effect>

                                <ItemsControl ItemsSource="{Binding CurrentReport.Bands}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#4A90D9" BorderThickness="1" 
                                                    Background="#F8F8F8" Margin="0,2"
                                                    MinHeight="{Binding Height}"
                                                    Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Band Header -->
                                                    <Border Grid.Row="0" Background="#2D5A8A" Padding="5,2">
                                                        <TextBlock Text="{Binding DisplayName}" 
                                                                   Foreground="White" FontSize="10"/>
                                                    </Border>

                                                    <!-- Components Container -->
                                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Components}"
                                                                  Margin="5">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style>
                                                                <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                                <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="{Binding Width}" Height="{Binding Height}"
                                                                        Background="{Binding Background}"
                                                                        BorderBrush="{Binding BorderColor}"
                                                                        BorderThickness="{Binding BorderWidth}"
                                                                        Cursor="SizeAll"
                                                                        MouseLeftButtonDown="Component_MouseLeftButtonDown"
                                                                        MouseMove="Component_MouseMove"
                                                                        MouseLeftButtonUp="Component_MouseLeftButtonUp">
                                                                    <Border.ToolTip>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Name}"/>
                                                                            <TextBlock Text="{Binding DataBinding}"/>
                                                                        </StackPanel>
                                                                    </Border.ToolTip>
                                                                    <Grid>
                                                                        <!-- TextBox -->
                                                                        <TextBlock Text="{Binding Text}"
                                                                                   Visibility="{Binding ComponentType, Converter={StaticResource ComponentTypeToVisibilityConverter}, ConverterParameter=TextBox}"
                                                                                   HorizontalAlignment="{Binding HorizontalAlignment}"
                                                                                   VerticalAlignment="{Binding VerticalAlignment}"
                                                                                   Margin="4"
                                                                                   FontFamily="{Binding FontFamily}"
                                                                                   FontSize="{Binding FontSize}"
                                                                                   FontWeight="{Binding FontWeight}"
                                                                                   FontStyle="{Binding FontStyle}"
                                                                                   Foreground="{Binding Foreground}"
                                                                                   TextWrapping="Wrap"/>
                                                                        
                                                                        <!-- Picture -->
                                                                        <TextBlock Text="🖼️ 图片"
                                                                                   Visibility="{Binding ComponentType, Converter={StaticResource ComponentTypeToVisibilityConverter}, ConverterParameter=Picture}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="#999"/>
                                                                        
                                                                        <!-- Table -->
                                                                        <TextBlock Text="📊 表格"
                                                                                   Visibility="{Binding ComponentType, Converter={StaticResource ComponentTypeToVisibilityConverter}, ConverterParameter=Table}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="#999"/>
                                                                        
                                                                        <!-- Chart -->
                                                                        <TextBlock Text="📈 图表"
                                                                                   Visibility="{Binding ComponentType, Converter={StaticResource ComponentTypeToVisibilityConverter}, ConverterParameter=Chart}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="#999"/>
                                                                        
                                                                        <!-- Line -->
                                                                        <Rectangle Fill="{Binding BorderColor}"
                                                                                   Visibility="{Binding ComponentType, Converter={StaticResource ComponentTypeToVisibilityConverter}, ConverterParameter=Line}"
                                                                                   Height="{Binding Height}"
                                                                                   VerticalAlignment="Center"/>
                                                                        
                                                                        <!-- Barcode -->
                                                                        <TextBlock Text="📶 条形码"
                                                                                   Visibility="{Binding ComponentType, Converter={StaticResource ComponentTypeToVisibilityConverter}, ConverterParameter=Barcode}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="#999"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Preview Mode -->
                <Grid Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Preview Header -->
                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="报表预览 - " Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="{Binding CurrentReport.Name}" Foreground="White" FontSize="14"/>
                            <Button Content="关闭预览" Command="{Binding ClosePreviewCommand}" 
                                    Margin="20,0,0,0" Background="White" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Preview Content -->
                    <Border Grid.Row="1" Background="{StaticResource DesignerBackgroundBrush}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="20" Background="White" MinHeight="600">
                                <Grid.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
                                </Grid.Effect>

                                <StackPanel>
                                    <!-- Static Bands -->
                                    <ItemsControl ItemsSource="{Binding CurrentReport.Bands}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <!-- Report Title -->
                                                    <Border Visibility="{Binding BandType, Converter={StaticResource BandTypeToVisibilityConverter}, ConverterParameter=ReportTitle}"
                                                            Background="#F0F0F0" Padding="20,30">
                                                        <TextBlock Text="{Binding Components[0].Text}" 
                                                                   FontSize="24" FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="#2D5A8A"/>
                                                    </Border>

                                                    <!-- Page Header -->
                                                    <Border Visibility="{Binding BandType, Converter={StaticResource BandTypeToVisibilityConverter}, ConverterParameter=PageHeader}"
                                                            Background="#F8F8F8" Padding="10,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                                        <ItemsControl ItemsSource="{Binding Components}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Text}" Margin="0,0,20,0"
                                                                               FontWeight="SemiBold"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                    </Border>

                                                    <!-- Data Band -->
                                                    <ItemsControl Visibility="{Binding BandType, Converter={StaticResource BandTypeToVisibilityConverter}, ConverterParameter=Data}"
                                                                   ItemsSource="{Binding DataContext.PreviewData, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   Margin="0,10">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10,5">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <ItemsControl ItemsSource="{Binding DataContext.SelectedBand.Components, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <StackPanel Orientation="Horizontal"/>
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock Text="{Binding Text}" Width="150" Margin="0,0,10,0"/>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Page Footer -->
                                                    <Border Visibility="{Binding BandType, Converter={StaticResource BandTypeToVisibilityConverter}, ConverterParameter=PageFooter}"
                                                            Background="#F8F8F8" Padding="10,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                                                        <TextBlock Text="- 第 1 页 -" HorizontalAlignment="Center" Foreground="#666"/>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- Right Panel - Properties -->
            <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Properties Header -->
                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="10,8">
                        <TextBlock Text="属性" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                    </Border>

                    <!-- Properties Panel -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">
                            <!-- General Properties -->
                            <Expander Header="常规" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <Label Content="名称"/>
                                    <TextBox Text="{Binding SelectedComponent.Name, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    
                                    <Label Content="类型" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.ComponentType}" IsReadOnly="True"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    
                                    <Label Content="可见性" Margin="0,8,0,0"/>
                                    <CheckBox Content="可见" IsChecked="{Binding SelectedComponent.Visible}"
                                              IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                </StackPanel>
                            </Expander>

                            <!-- Position Properties -->
                            <Expander Header="位置和大小" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,4,4">
                                            <Label Content="左边"/>
                                            <TextBox Text="{Binding SelectedComponent.Left, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="4,0,0,4">
                                            <Label Content="顶边"/>
                                            <TextBox Text="{Binding SelectedComponent.Top, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,4,4,0">
                                            <Label Content="宽度"/>
                                            <TextBox Text="{Binding SelectedComponent.Width, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="4,4,0,0">
                                            <Label Content="高度"/>
                                            <TextBox Text="{Binding SelectedComponent.Height, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <!-- Text Properties -->
                            <Expander Header="文本" IsExpanded="True" Margin="0,0,0,8"
                                      Visibility="{Binding SelectedComponent.ComponentType, Converter={StaticResource ComponentTypeToVisibilityConverter}, ConverterParameter=TextBox}">
                                <StackPanel Margin="8">
                                    <Label Content="文本"/>
                                    <TextBox Text="{Binding SelectedComponent.Text, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"
                                             TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
                                    
                                    <Label Content="数据绑定" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.DataBinding, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"
                                             ToolTip="例如: {CustomerName}"/>
                                </StackPanel>
                            </Expander>

                            <!-- Font Properties -->
                            <Expander Header="字体" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <Label Content="字体"/>
                                    <ComboBox SelectedValue="{Binding SelectedComponent.FontFamily}" 
                                              SelectedValuePath="Content"
                                              IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}">
                                        <ComboBoxItem Content="Segoe UI"/>
                                        <ComboBoxItem Content="Arial"/>
                                        <ComboBoxItem Content="Times New Roman"/>
                                        <ComboBoxItem Content="Consolas"/>
                                    </ComboBox>
                                    
                                    <Label Content="字号" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.FontSize, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox Content="粗体" IsChecked="{Binding SelectedComponent.FontBold}"
                                                  IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"
                                                  Margin="0,0,16,0"/>
                                        <CheckBox Content="斜体" IsChecked="{Binding SelectedComponent.FontItalic}"
                                                  IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- Appearance Properties -->
                            <Expander Header="外观" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <Label Content="前景色"/>
                                    <TextBox Text="{Binding SelectedComponent.Foreground, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    
                                    <Label Content="背景色" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.Background, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    
                                    <Label Content="边框颜色" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.BorderColor, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    
                                    <Label Content="边框宽度" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.BorderWidth, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                </StackPanel>
                            </Expander>

                            <!-- Script Properties -->
                            <Expander Header="脚本" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="8">
                                    <CheckBox Content="启用脚本" IsChecked="{Binding SelectedComponent.UseScript}"
                                              IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"/>
                                    
                                    <Label Content="表达式脚本" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.Script, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent.UseScript, FallbackValue=False}"
                                             TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                             FontFamily="Consolas" FontSize="12"/>
                                    
                                    <Label Content="OnBeforePrint" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.OnBeforePrintScript, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"
                                             TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                             FontFamily="Consolas" FontSize="12"
                                             ToolTip="打印前执行的代码"/>
                                    
                                    <Label Content="OnGetValue" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.OnGetValueScript, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"
                                             TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                             FontFamily="Consolas" FontSize="12"
                                             ToolTip="获取值时执行的代码，返回值为显示内容"/>
                                    
                                    <Label Content="OnAfterPrint" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.OnAfterPrintScript, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"
                                             TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                             FontFamily="Consolas" FontSize="12"
                                             ToolTip="打印后执行的代码"/>
                                    
                                    <Label Content="OnFormatting" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding SelectedComponent.OnFormattingScript, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBoolConverter}}"
                                             TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                             FontFamily="Consolas" FontSize="12"
                                             ToolTip="格式化时执行的代码，返回颜色字符串如 '#FF0000'"/>
                                    
                                    <TextBlock Text="C# 脚本示例:&amp;#10;• Data[&amp;quot;FieldName&amp;quot;] 访问数据字段&amp;#10;• Report 访问报表对象&amp;#10;• Call(&amp;quot;FunctionName&amp;quot;, args) 调用函数"
                                               TextWrapping="Wrap" Margin="0,8,0,0" FontSize="10" Foreground="#666"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Data Sources Header -->
                    <Border Grid.Row="2" Background="{StaticResource SecondaryBrush}" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="数据源" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                            <Button Content="+" Command="{Binding AddDataSourceCommand}" 
                                    Margin="10,0,0,0" Width="24" Height="24" 
                                    Background="White" Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Data Sources List -->
                    <ListBox Grid.Row="3" ItemsSource="{Binding DataSources}" 
                             SelectedItem="{Binding SelectedDataSource}" Margin="4"
                             Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DataSourceType}" FontSize="10" Foreground="#666"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Data Source Properties -->
                    <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                            Background="White" Margin="4" Padding="8"
                            Visibility="{Binding SelectedDataSource, Converter={StaticResource NullToBoolConverter}, ConverterParameter=True}">
                        <StackPanel>
                            <TextBlock Text="数据源属性" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource PrimaryBrush}"/>
                            
                            <Label Content="名称"/>
                            <TextBox Text="{Binding SelectedDataSource.Name, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding SelectedDataSource, Converter={StaticResource NullToBoolConverter}}"/>
                            
                            <Label Content="类型" Margin="0,8,0,0"/>
                            <ComboBox SelectedItem="{Binding SelectedDataSource.DataSourceType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding SelectedDataSource, Converter={StaticResource NullToBoolConverter}}"
                                      Width="150">
                                <ComboBoxItem>SQLite</ComboBoxItem>
                                <ComboBoxItem>CSV</ComboBoxItem>
                                <ComboBoxItem>JSON</ComboBoxItem>
                                <ComboBoxItem>SqlServer</ComboBoxItem>
                                <ComboBoxItem>Object</ComboBoxItem>
                            </ComboBox>
                            
                            <Label Content="连接字符串" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding SelectedDataSource.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding SelectedDataSource, Converter={StaticResource NullToBoolConverter}}"
                                     ToolTip="SQLite: Data Source=path/to/file.db"/>
                            
                            <Label Content="查询语句" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding SelectedDataSource.Query, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding SelectedDataSource, Converter={StaticResource NullToBoolConverter}}"
                                     TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
                            
                            <Label Content="表名" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding SelectedDataSource.TableName, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding SelectedDataSource, Converter={StaticResource NullToBoolConverter}}"/>
                            
                            <Label Content="文件路径" Margin="0,8,0,0"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding SelectedDataSource.FilePath, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding SelectedDataSource, Converter={StaticResource NullToBoolConverter}}"
                                         Width="200"/>
                                <Button Content="..." Width="24" Margin="4,0,0,0"
                                        Click="BrowseFilePath_Click"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="测试连接" Command="{Binding TestDataSourceConnectionCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="刷新字段" Command="{Binding RefreshDataSourceFieldsCommand}"/>
                            </StackPanel>
                            
                            <Label Content="字段列表" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding SelectedDataSource.Fields}" Height="80"
                                     IsEnabled="{Binding SelectedDataSource.IsConnected, FallbackValue=False}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Width="120"/>
                                            <TextBlock Text="{Binding DataType}" FontSize="10" Foreground="#666"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="就绪"/>
                    <Run Text=" | 缩放: "/>
                    <Run Text="{Binding ZoomLevel, StringFormat={}{0:P0}}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="报表: "/>
                    <Run Text="{Binding CurrentReport.Name}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="组件数: "/>
                    <Run Text="{Binding SelectedBand.Components.Count, Mode=OneWay, FallbackValue=0}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding CurrentFilePath}" Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
